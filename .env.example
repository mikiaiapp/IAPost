# ==========================================
# IAPost - Environment Configuration
# ==========================================
# Copy this file to .env and fill in values

# Database
DATABASE_URL=sqlite:///./data/iapost.db
# For PostgreSQL: DATABASE_URL=postgresql://user:password@localhost:5432/iapost

# Security (generate with: openssl rand -hex 32)
SECRET_KEY=change-me-to-a-random-32-char-secret
ENCRYPTION_KEY=change-me-to-a-fernet-key

# Cartero Email Service
CARTERO_URL=http://192.168.1.2:3001/send
CARTERO_KEY=your-cartero-api-key

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://192.168.1.2:3000

# Scheduler (daily run time, 24h format)
SCHEDULER_HOUR=6
SCHEDULER_MINUTE=30

# Frontend API URL
VITE_API_URL=http://192.168.1.2:8000

# Timezone
TZ=Europe/Madrid
